---
import Shell from '../layouts/Shell.astro';
import Icon from '../components/Icon.astro';
---

<Shell title="Upload" active="upload">
  <div class="stack" style="gap: 20px; max-width: 720px;">
    <header>
      <h1 class="h1" style="font-size: 28px;">Upload an activity</h1>
      <p class="muted body-sm" style="margin-top: 4px;">
        Drag a FIT, TCX, or GPX file onto the box, or click to choose. Your browser uploads it
        directly to the API; parsing and metric computation happen in the background.
      </p>
    </header>

    <label id="drop" class="dropzone">
      <div class="stack" style="gap: 6px; align-items: center;">
        <Icon name="upload" size={28} />
        <strong style="font-size: 15px;">Drop file here</strong>
        <span class="caption">or click to choose · max 25 MB · .fit / .tcx / .gpx</span>
      </div>
      <input id="file-input" type="file" accept=".fit,.tcx,.gpx" style="display: none;" />
    </label>

    <ul id="results" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 8px;" aria-live="polite"></ul>
  </div>
</Shell>

<script>
  const drop = document.getElementById('drop')!;
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const results = document.getElementById('results')!;

  const SOURCE_BY_EXT: Record<string, 'fit' | 'tcx' | 'gpx'> = {
    fit: 'fit',
    tcx: 'tcx',
    gpx: 'gpx',
  };

  drop.addEventListener('dragover', (e) => {
    e.preventDefault();
    drop.classList.add('is-dragging');
  });
  drop.addEventListener('dragleave', () => drop.classList.remove('is-dragging'));
  drop.addEventListener('drop', async (e) => {
    e.preventDefault();
    drop.classList.remove('is-dragging');
    const files = Array.from(e.dataTransfer?.files ?? []);
    for (const f of files) await upload(f);
  });
  fileInput.addEventListener('change', async () => {
    if (!fileInput.files) return;
    for (const f of Array.from(fileInput.files)) await upload(f);
    fileInput.value = '';
  });

  async function upload(file: File) {
    const ext = file.name.toLowerCase().split('.').pop() ?? '';
    const source = SOURCE_BY_EXT[ext];
    const li = document.createElement('li');
    li.className = 'panel';
    li.innerHTML = `<div style="padding: 12px 16px;"><span class="metric-label">uploading</span> · ${escape(file.name)}</div>`;
    results.appendChild(li);

    if (!source) {
      li.innerHTML = `<div style="padding: 12px 16px; color: var(--danger);">${escape(file.name)} — unsupported extension</div>`;
      return;
    }
    if (file.size > 25 * 1024 * 1024) {
      li.innerHTML = `<div style="padding: 12px 16px; color: var(--danger);">${escape(file.name)} — too large (>25 MB)</div>`;
      return;
    }

    try {
      const buf = await file.arrayBuffer();
      const res = await fetch('/api/v1/activities', {
        method: 'POST',
        credentials: 'include',
        headers: {
          'Content-Type':
            source === 'fit'
              ? 'application/octet-stream'
              : source === 'gpx'
                ? 'application/gpx+xml'
                : 'application/tcx+xml',
          'X-Activity-Source': source,
        },
        body: buf,
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({ error: res.statusText }));
        throw new Error(err.error ?? `HTTP ${res.status}`);
      }
      const body = (await res.json()) as { activityId: string };
      li.innerHTML = `
        <div style="padding: 12px 16px; display: flex; align-items: center; gap: 12px;">
          <span class="chip chip-success">queued</span>
          <span style="flex: 1;">${escape(file.name)}</span>
          <a class="btn btn-secondary btn-sm" href="/activity/${escape(body.activityId)}">View</a>
        </div>
      `;
    } catch (err) {
      li.innerHTML = `<div style="padding: 12px 16px; color: var(--danger);">${escape(file.name)} — failed: ${escape((err as Error).message)}</div>`;
    }
  }

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>

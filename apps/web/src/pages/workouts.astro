---
import Base from '../layouts/Base.astro';
---

<Base title="Workouts · pacelore">
  <section class="space-y-6">
    <h1 class="text-2xl font-bold">Workouts</h1>
    <p class="text-sm text-neutral-600 dark:text-neutral-400">
      Build a structured session and reuse it on the calendar. Export to a FIT file for your
      Garmin or a .zwo for Zwift.
    </p>

    <details class="rounded border border-neutral-200 p-3 dark:border-neutral-800">
      <summary class="cursor-pointer font-medium">New workout</summary>
      <form id="new-workout" class="mt-3 space-y-3">
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          <label class="block text-sm">Name
            <input
              name="name"
              required
              class="mt-1 w-full rounded border border-neutral-300 px-3 py-2 dark:border-neutral-700 dark:bg-neutral-900"
            />
          </label>
          <label class="block text-sm">Sport
            <select
              name="sport"
              class="mt-1 w-full rounded border border-neutral-300 px-3 py-2 dark:border-neutral-700 dark:bg-neutral-900"
            >
              <option value="cycling">Cycling</option>
              <option value="running">Running</option>
              <option value="swimming">Swimming</option>
              <option value="other">Other</option>
            </select>
          </label>
        </div>
        <div>
          <p class="text-sm font-medium">Steps</p>
          <ol id="step-list" class="mt-2 space-y-2 text-sm"></ol>
          <button
            type="button"
            id="add-step"
            class="mt-2 rounded border border-neutral-300 px-3 py-1.5 text-sm dark:border-neutral-700"
            >+ step</button
          >
        </div>
        <button class="rounded bg-accent px-3 py-1.5 text-sm font-medium text-white">Save</button>
        <p id="save-status" aria-live="polite" class="text-sm"></p>
      </form>
    </details>

    <ul id="workout-list" class="space-y-2 text-sm"></ul>
  </section>
</Base>

<script>
  type StepKind = 'warmup' | 'work' | 'recover' | 'cooldown' | 'rest';
  interface Step {
    kind: StepKind;
    durationSec: number;
    target?: { type: 'ftp_pct' | 'hr_pct'; low: number; high: number };
  }

  const stepList = document.getElementById('step-list')!;
  const workoutList = document.getElementById('workout-list')!;
  const status = document.getElementById('save-status')!;
  const form = document.getElementById('new-workout') as HTMLFormElement;
  const addStepBtn = document.getElementById('add-step')!;

  const steps: Step[] = [];
  addStep();
  void loadList();

  addStepBtn.addEventListener('click', () => addStep());

  function addStep() {
    steps.push({ kind: 'work', durationSec: 300 });
    renderSteps();
  }

  function renderSteps() {
    stepList.innerHTML = '';
    steps.forEach((step, i) => {
      const li = document.createElement('li');
      li.className = 'rounded border border-neutral-200 p-2 dark:border-neutral-800';
      li.innerHTML = `
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-5">
          <select data-i="${i}" data-f="kind" class="rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900">
            ${(['warmup', 'work', 'recover', 'cooldown', 'rest'] as StepKind[])
              .map((k) => `<option value="${k}" ${k === step.kind ? 'selected' : ''}>${k}</option>`)
              .join('')}
          </select>
          <label class="text-xs">duration (s)
            <input data-i="${i}" data-f="duration" type="number" value="${step.durationSec}" class="w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900" />
          </label>
          <label class="text-xs">target
            <select data-i="${i}" data-f="targetType" class="w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900">
              <option value="" ${!step.target ? 'selected' : ''}>—</option>
              <option value="ftp_pct" ${step.target?.type === 'ftp_pct' ? 'selected' : ''}>%FTP</option>
              <option value="hr_pct" ${step.target?.type === 'hr_pct' ? 'selected' : ''}>%HRmax</option>
            </select>
          </label>
          <label class="text-xs">low
            <input data-i="${i}" data-f="low" type="number" value="${step.target?.low ?? ''}" class="w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900" />
          </label>
          <label class="text-xs">high
            <input data-i="${i}" data-f="high" type="number" value="${step.target?.high ?? ''}" class="w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900" />
          </label>
        </div>
        <button type="button" data-remove="${i}" class="mt-1 text-xs text-red-600 hover:underline">remove</button>
      `;
      stepList.appendChild(li);
    });
  }

  stepList.addEventListener('change', (ev) => {
    const t = ev.target as HTMLInputElement | HTMLSelectElement;
    const i = Number(t.dataset.i);
    if (Number.isNaN(i)) return;
    const step = steps[i]!;
    const f = t.dataset.f;
    if (f === 'kind') step.kind = t.value as StepKind;
    if (f === 'duration') step.durationSec = Math.max(0, Number(t.value) || 0);
    if (f === 'targetType') {
      if (!t.value) step.target = undefined;
      else step.target = { type: t.value as 'ftp_pct' | 'hr_pct', low: 0, high: 0 };
    }
    if (f === 'low' || f === 'high') {
      if (!step.target) step.target = { type: 'ftp_pct', low: 0, high: 0 };
      step.target[f as 'low' | 'high'] = Number(t.value) || 0;
    }
  });

  stepList.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement;
    const idx = t.dataset.remove;
    if (idx == null) return;
    steps.splice(Number(idx), 1);
    renderSteps();
  });

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const fd = new FormData(form);
    const payload = {
      name: String(fd.get('name') ?? ''),
      sport: String(fd.get('sport') ?? 'cycling'),
      steps,
    };
    const r = await fetch('/api/v1/workouts', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (r.ok) {
      const body = (await r.json()) as { id: string; estimatedTss: number | null };
      status.textContent = `Saved · est ${body.estimatedTss?.toFixed(1) ?? '–'} TSS`;
      form.reset();
      steps.length = 0;
      addStep();
      await loadList();
    } else {
      status.textContent = `Failed: HTTP ${r.status}`;
    }
  });

  async function loadList() {
    const r = await fetch('/api/v1/workouts', { credentials: 'include' });
    if (!r.ok) return;
    const body = (await r.json()) as {
      items: {
        id: string;
        name: string;
        sport: string;
        estimatedTss: number | null;
        estimatedDurationSec: number | null;
      }[];
    };
    workoutList.innerHTML = '';
    for (const w of body.items) {
      const li = document.createElement('li');
      li.className = 'rounded border border-neutral-200 p-3 dark:border-neutral-800';
      const dur = w.estimatedDurationSec
        ? `${Math.round(w.estimatedDurationSec / 60)} min`
        : '—';
      const tss = w.estimatedTss != null ? `${w.estimatedTss.toFixed(1)} TSS` : '—';
      li.innerHTML = `
        <div class="flex items-center justify-between">
          <div>
            <p class="font-medium">${escape(w.name)}</p>
            <p class="text-xs text-neutral-500">${w.sport} · ${dur} · ${tss}</p>
          </div>
          <div class="flex gap-2 text-xs">
            <a class="rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700" href="/api/v1/workouts/${w.id}/export.fit">FIT</a>
            <a class="rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700" href="/api/v1/workouts/${w.id}/export.zwo">ZWO</a>
            <button data-del="${w.id}" class="rounded text-red-600 hover:underline">delete</button>
          </div>
        </div>
      `;
      workoutList.appendChild(li);
    }
  }

  workoutList.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement;
    const id = t.dataset.del;
    if (!id) return;
    const r = await fetch(`/api/v1/workouts/${id}`, { method: 'DELETE', credentials: 'include' });
    if (r.ok) await loadList();
  });

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>

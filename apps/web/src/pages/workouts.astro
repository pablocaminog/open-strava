---
import Shell from '../layouts/Shell.astro';
import Icon from '../components/Icon.astro';
---

<Shell title="Workouts" active="workouts">
  <div class="stack" style="gap: 20px;">
    <header style="display: flex; align-items: flex-start; gap: 16px;">
      <div style="flex: 1;">
        <h1 class="h1" style="font-size: 28px;">Workouts</h1>
        <p class="muted body-sm" style="margin-top: 4px;">
          Build a structured session and reuse it on the calendar. Export to FIT for your Garmin or
          .zwo for Zwift.
        </p>
      </div>
      <button id="prefill-btn" type="button" class="btn btn-secondary btn-sm">
        Prefill 60 starter workouts
      </button>
    </header>
    <p id="prefill-status" class="caption" aria-live="polite"></p>

    <details class="panel">
      <summary style="cursor: pointer; padding: 14px 20px; display: flex; align-items: center; gap: 8px; font-weight: 500;">
        <Icon name="plus" size={16} /> New workout
      </summary>
      <form id="new-workout" class="panel-body stack" style="gap: 14px;">
        <div class="grid-tiles grid-cols-2" style="gap: 14px;">
          <div class="field">
            <label class="field-label">Name</label>
            <input class="input" name="name" required />
          </div>
          <div class="field">
            <label class="field-label">Sport</label>
            <select class="select" name="sport">
              <option value="cycling">Cycling</option>
              <option value="running">Running</option>
              <option value="swimming">Swimming</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
        <div>
          <span class="metric-label" style="display: block; margin-bottom: 8px;">Steps</span>
          <ol id="step-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 8px;"></ol>
          <button type="button" id="add-step" class="btn btn-secondary btn-sm" style="margin-top: 8px;">
            <Icon name="plus" size={14} /> Add step
          </button>
        </div>
        <div class="row" style="gap: 12px;">
          <button class="btn btn-primary" type="submit">Save workout</button>
          <p id="save-status" class="caption" aria-live="polite"></p>
        </div>
      </form>
    </details>

    <ul id="workout-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 10px;"></ul>
  </div>
</Shell>

<script>
  import { WORKOUT_LIBRARY } from '../data/workout-library.ts';

  type StepKind = 'warmup' | 'work' | 'recover' | 'cooldown' | 'rest';
  interface Step {
    kind: StepKind;
    durationSec: number;
    target?: { type: 'ftp_pct' | 'hr_pct'; low: number; high: number };
  }

  const stepList = document.getElementById('step-list')!;
  const workoutList = document.getElementById('workout-list')!;
  const status = document.getElementById('save-status')!;
  const form = document.getElementById('new-workout') as HTMLFormElement;
  const addStepBtn = document.getElementById('add-step')!;

  const steps: Step[] = [];
  addStep();
  void loadList();

  addStepBtn.addEventListener('click', () => addStep());

  const prefillBtn = document.getElementById('prefill-btn') as HTMLButtonElement | null;
  const prefillStatus = document.getElementById('prefill-status')!;
  prefillBtn?.addEventListener('click', async () => {
    if (!confirm(`Add ${WORKOUT_LIBRARY.length} starter workouts to your library?`)) return;
    prefillBtn.disabled = true;
    let ok = 0;
    let fail = 0;
    for (let i = 0; i < WORKOUT_LIBRARY.length; i++) {
      const w = WORKOUT_LIBRARY[i]!;
      prefillStatus.textContent = `Seeding ${i + 1}/${WORKOUT_LIBRARY.length}: ${w.name}…`;
      try {
        const r = await fetch('/api/v1/workouts', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: w.name,
            description: w.description,
            sport: w.sport,
            steps: w.steps,
          }),
        });
        if (r.ok) ok++;
        else fail++;
      } catch {
        fail++;
      }
    }
    prefillStatus.textContent = `Done · ${ok} added${fail > 0 ? ` · ${fail} failed` : ''}.`;
    prefillBtn.disabled = false;
    await loadList();
  });

  function addStep() {
    steps.push({ kind: 'work', durationSec: 300 });
    renderSteps();
  }

  function renderSteps() {
    stepList.innerHTML = '';
    steps.forEach((step, i) => {
      const li = document.createElement('li');
      li.className = 'panel';
      li.innerHTML = `
        <div style="padding: 12px 14px; display: grid; grid-template-columns: 110px 110px 110px 80px 80px auto; gap: 8px; align-items: end;">
          <div class="field"><span class="caption">kind</span>
            <select class="select" data-i="${i}" data-f="kind">
              ${(['warmup', 'work', 'recover', 'cooldown', 'rest'] as StepKind[])
                .map((k) => `<option value="${k}" ${k === step.kind ? 'selected' : ''}>${k}</option>`)
                .join('')}
            </select>
          </div>
          <div class="field"><span class="caption">duration (s)</span>
            <input class="input mono" data-i="${i}" data-f="duration" type="number" value="${step.durationSec}" />
          </div>
          <div class="field"><span class="caption">target</span>
            <select class="select" data-i="${i}" data-f="targetType">
              <option value="" ${!step.target ? 'selected' : ''}>—</option>
              <option value="ftp_pct" ${step.target?.type === 'ftp_pct' ? 'selected' : ''}>%FTP</option>
              <option value="hr_pct" ${step.target?.type === 'hr_pct' ? 'selected' : ''}>%HRmax</option>
            </select>
          </div>
          <div class="field"><span class="caption">low</span>
            <input class="input mono" data-i="${i}" data-f="low" type="number" value="${step.target?.low ?? ''}" />
          </div>
          <div class="field"><span class="caption">high</span>
            <input class="input mono" data-i="${i}" data-f="high" type="number" value="${step.target?.high ?? ''}" />
          </div>
          <button type="button" data-remove="${i}" class="btn btn-ghost btn-sm" style="color: var(--danger);">Remove</button>
        </div>
      `;
      stepList.appendChild(li);
    });
  }

  stepList.addEventListener('change', (ev) => {
    const t = ev.target as HTMLInputElement | HTMLSelectElement;
    const i = Number(t.dataset.i);
    if (Number.isNaN(i)) return;
    const step = steps[i]!;
    const f = t.dataset.f;
    if (f === 'kind') step.kind = t.value as StepKind;
    if (f === 'duration') step.durationSec = Math.max(0, Number(t.value) || 0);
    if (f === 'targetType') {
      if (!t.value) step.target = undefined;
      else step.target = { type: t.value as 'ftp_pct' | 'hr_pct', low: 0, high: 0 };
    }
    if (f === 'low' || f === 'high') {
      if (!step.target) step.target = { type: 'ftp_pct', low: 0, high: 0 };
      step.target[f as 'low' | 'high'] = Number(t.value) || 0;
    }
  });

  stepList.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement;
    const idx = t.dataset.remove;
    if (idx == null) return;
    steps.splice(Number(idx), 1);
    renderSteps();
  });

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const fd = new FormData(form);
    const payload = {
      name: String(fd.get('name') ?? ''),
      sport: String(fd.get('sport') ?? 'cycling'),
      steps,
    };
    const r = await fetch('/api/v1/workouts', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (r.ok) {
      const body = (await r.json()) as { id: string; estimatedTss: number | null };
      status.textContent = `Saved · est ${body.estimatedTss?.toFixed(0) ?? '—'} TSS`;
      form.reset();
      steps.length = 0;
      addStep();
      await loadList();
    } else {
      status.textContent = `Couldn't save · HTTP ${r.status}`;
    }
  });

  async function loadList() {
    const r = await fetch('/api/v1/workouts', { credentials: 'include' });
    if (!r.ok) return;
    const body = (await r.json()) as {
      items: {
        id: string;
        name: string;
        sport: string;
        estimatedTss: number | null;
        estimatedDurationSec: number | null;
      }[];
    };
    workoutList.innerHTML = '';
    if (body.items.length === 0) {
      workoutList.innerHTML = `<li class="empty">No workouts yet.</li>`;
      return;
    }
    for (const w of body.items) {
      const li = document.createElement('li');
      li.className = 'panel';
      const dur = w.estimatedDurationSec ? `${Math.round(w.estimatedDurationSec / 60)} min` : '—';
      const tss = w.estimatedTss != null ? `${w.estimatedTss.toFixed(0)} TSS` : '—';
      li.innerHTML = `
        <div style="padding: 14px 20px; display: flex; align-items: center; gap: 12px;">
          <div style="flex: 1;">
            <strong style="font-size: 15px;">${escape(w.name)}</strong>
            <p class="caption" style="margin-top: 2px;">${escape(w.sport)} · ${dur} · ${tss}</p>
          </div>
          <a class="btn btn-secondary btn-sm" href="/api/v1/workouts/${escape(w.id)}/export.fit">FIT</a>
          <a class="btn btn-secondary btn-sm" href="/api/v1/workouts/${escape(w.id)}/export.zwo">ZWO</a>
          <button data-del="${escape(w.id)}" class="btn btn-ghost btn-sm" style="color: var(--danger);">Delete</button>
        </div>
      `;
      workoutList.appendChild(li);
    }
  }

  workoutList.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement;
    const id = t.dataset.del;
    if (!id) return;
    const r = await fetch(`/api/v1/workouts/${id}`, { method: 'DELETE', credentials: 'include' });
    if (r.ok) await loadList();
  });

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>

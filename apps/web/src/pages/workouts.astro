---
import Shell from '../layouts/Shell.astro';
import Icon from '../components/Icon.astro';
---

<Shell title="Workouts" active="workouts">
  <div class="stack" style="gap: 24px;">
    <header>
      <h1 class="h1" style="font-size: 28px;">Workouts</h1>
      <p class="muted body-sm" style="margin-top: 4px;">
        Pick a session from the library, or build your own. Schedule on the calendar; export to
        FIT for Garmin or .zwo for Zwift.
      </p>
    </header>

    <section class="stack" style="gap: 12px;">
      <div class="row" style="gap: 12px; flex-wrap: wrap;">
        <h2 class="h3" style="font-size: 18px;">Library</h2>
        <span id="library-count" class="metric-label row-end"></span>
      </div>

      <div class="panel">
        <div class="panel-body stack" style="gap: 12px;">
          <div class="row" style="gap: 16px; flex-wrap: wrap;">
            <div class="row" style="gap: 8px;">
              <span class="metric-label" style="margin-right: 4px;">Sport</span>
              <div class="segmented" id="filter-sport">
                <button type="button" data-v="all" class="on">All</button>
                <button type="button" data-v="cycling">Cycling</button>
                <button type="button" data-v="running">Running</button>
                <button type="button" data-v="swimming">Swimming</button>
              </div>
            </div>
            <div class="row" style="gap: 8px;">
              <span class="metric-label" style="margin-right: 4px;">Duration</span>
              <div class="segmented" id="filter-duration">
                <button type="button" data-v="all" class="on">Any</button>
                <button type="button" data-v="short">&lt; 30 min</button>
                <button type="button" data-v="mid">30 – 60 min</button>
                <button type="button" data-v="long">&gt; 60 min</button>
              </div>
            </div>
            <div class="row" style="gap: 8px;">
              <span class="metric-label" style="margin-right: 4px;">Intensity</span>
              <div class="segmented" id="filter-zone">
                <button type="button" data-v="all" class="on">Any</button>
                <button type="button" data-v="1">Z1</button>
                <button type="button" data-v="2">Z2</button>
                <button type="button" data-v="3">Z3</button>
                <button type="button" data-v="4">Z4</button>
                <button type="button" data-v="5">Z5</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <ul id="library-list" class="grid-tiles" style="grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 12px; list-style: none; margin: 0; padding: 0;"></ul>
    </section>

    <details class="panel" id="new-workout-panel">
      <summary style="cursor: pointer; padding: 14px 20px; display: flex; align-items: center; gap: 8px; font-weight: 500;">
        <Icon name="plus" size={16} /> New custom workout
      </summary>
      <div class="panel-body stack" style="gap: 14px;">
        <div class="segmented" id="entry-mode" style="align-self: flex-start;">
          <button type="button" data-v="steps" class="on">Step builder</button>
          <button type="button" data-v="csv">Paste CSV</button>
        </div>

        <form id="new-workout" class="stack" style="gap: 14px;">
          <div class="grid-tiles grid-cols-2" style="gap: 14px;">
            <div class="field">
              <label class="field-label">Name</label>
              <input class="input" name="name" required />
            </div>
            <div class="field">
              <label class="field-label">Sport</label>
              <select class="select" name="sport">
                <option value="cycling">Cycling</option>
                <option value="running">Running</option>
                <option value="swimming">Swimming</option>
                <option value="other">Other</option>
              </select>
            </div>
          </div>
          <div>
            <span class="metric-label" style="display: block; margin-bottom: 8px;">Steps</span>
            <ol id="step-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 8px;"></ol>
            <button type="button" id="add-step" class="btn btn-secondary btn-sm" style="margin-top: 8px;">
              <Icon name="plus" size={14} /> Add step
            </button>
          </div>
          <div class="row" style="gap: 12px;">
            <button class="btn btn-primary" type="submit">Save workout</button>
            <p id="save-status" class="caption" aria-live="polite"></p>
          </div>
        </form>

        <div id="csv-panel" style="display: none;" class="stack" style="gap: 12px;">
          <div class="field">
            <label class="field-label">CSV text</label>
            <textarea
              id="csv-input"
              class="input"
              rows="8"
              placeholder="Z2 Ride, cycling, Easy aerobic base&#10;Warm up, 600, 80-150W&#10;Main Block, 2000, 170W&#10;Cool down, 600, 80-120W"
              style="font-family: monospace; font-size: 13px; resize: vertical;"
            ></textarea>
            <p class="caption" style="margin-top: 4px; opacity: 0.7;">
              Row 1: <code>name, sport[, description]</code> — Rows 2+: <code>block_name, duration_secs[, target]</code><br/>
              Targets: <code>170W</code> &nbsp;·&nbsp; <code>80-150W</code> &nbsp;·&nbsp; <code>75%</code> &nbsp;·&nbsp; <code>140bpm</code> &nbsp;·&nbsp; <code>4:30/km</code>
            </p>
          </div>
          <div id="csv-preview" style="display: none; padding: 12px; background: var(--surface-2); border-radius: 8px;">
            <p class="metric-label" style="margin-bottom: 8px;">Preview</p>
            <ol id="csv-preview-list" style="list-style: none; margin: 0; padding: 0; font-size: 13px;"></ol>
          </div>
          <p id="csv-error" class="caption" style="color: var(--color-red, #ef4444); display: none;"></p>
          <div class="row" style="gap: 12px;">
            <button id="csv-save" class="btn btn-primary">Save workout</button>
            <p id="csv-save-status" class="caption" aria-live="polite"></p>
          </div>
        </div>
      </div>
    </details>

    <section class="stack" style="gap: 12px;">
      <h2 class="h3" style="font-size: 18px;">Saved workouts</h2>
      <ul id="workout-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 10px;"></ul>
    </section>
  </div>
</Shell>

<script>
  import {
    WORKOUT_LIBRARY,
    type WorkoutDef,
    type WorkoutStepDef,
  } from '../data/workout-library.ts';
  import { parseWorkoutCsv, WorkoutCsvError } from '@pacelore/workout-csv';

  type StepKind = 'warmup' | 'work' | 'recover' | 'cooldown' | 'rest';
  interface Step {
    kind: StepKind;
    durationSec: number;
    target?: { type: 'ftp_pct' | 'hr_pct'; low: number; high: number };
  }

  // ------------- duration + zone helpers ----------------
  // Pace assumptions for distance-based steps (median, sport-relative).
  const PACE_M_PER_S: Record<WorkoutDef['sport'], number> = {
    cycling: 8.33, // ~30 km/h
    running: 3.33, // ~12 km/h, 5:00/km
    swimming: 1.4, // ~1:11/100m
  };

  function stepDurationSec(s: WorkoutStepDef, sport: WorkoutDef['sport']): number {
    if (s.children && s.children.length > 0) {
      const inner = s.children.reduce((a, c) => a + stepDurationSec(c, sport), 0);
      return inner * Math.max(1, s.repeat ?? 1);
    }
    if (s.durationSec) return s.durationSec * Math.max(1, s.repeat ?? 1);
    if (s.distM) return (s.distM / PACE_M_PER_S[sport]) * Math.max(1, s.repeat ?? 1);
    return 0;
  }

  function workoutDurationSec(w: WorkoutDef): number {
    return w.steps.reduce((a, s) => a + stepDurationSec(s, w.sport), 0);
  }

  function zoneOfTarget(t: WorkoutStepDef['target']): number {
    if (!t) return 0;
    const v = t.high;
    if (t.type === 'ftp_pct') {
      if (v < 66) return 1;
      if (v < 81) return 2;
      if (v < 91) return 3;
      if (v < 106) return 4;
      return 5;
    }
    // hr_pct (and pace fallback)
    if (v < 73) return 1;
    if (v < 83) return 2;
    if (v < 88) return 3;
    if (v < 93) return 4;
    return 5;
  }

  function peakZone(steps: WorkoutStepDef[]): number {
    let max = 0;
    const visit = (list: WorkoutStepDef[]) => {
      for (const s of list) {
        if (s.kind !== 'recover' && s.kind !== 'rest' && s.target) {
          const z = zoneOfTarget(s.target);
          if (z > max) max = z;
        }
        if (s.children) visit(s.children);
      }
    };
    visit(steps);
    return max;
  }

  function durationBucket(sec: number): 'short' | 'mid' | 'long' {
    if (sec < 30 * 60) return 'short';
    if (sec <= 60 * 60) return 'mid';
    return 'long';
  }

  // ------------- library state ----------------
  type LibEntry = WorkoutDef & {
    durationSec: number;
    bucket: 'short' | 'mid' | 'long';
    zone: number;
  };
  const LIB: LibEntry[] = WORKOUT_LIBRARY.map((w) => {
    const durationSec = workoutDurationSec(w);
    return {
      ...w,
      durationSec,
      bucket: durationBucket(durationSec),
      zone: peakZone(w.steps),
    };
  });

  const filters = { sport: 'all', duration: 'all', zone: 'all' };
  const libraryList = document.getElementById('library-list')!;
  const libraryCount = document.getElementById('library-count')!;

  function wireFilter(elId: string, key: keyof typeof filters) {
    const el = document.getElementById(elId)!;
    el.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const v = t.dataset.v;
      if (!v) return;
      filters[key] = v;
      el.querySelectorAll('button').forEach((b) => b.classList.toggle('on', b === t));
      renderLibrary();
    });
  }
  wireFilter('filter-sport', 'sport');
  wireFilter('filter-duration', 'duration');
  wireFilter('filter-zone', 'zone');

  function renderLibrary() {
    const matches = LIB.filter((w) => {
      if (filters.sport !== 'all' && w.sport !== filters.sport) return false;
      if (filters.duration !== 'all' && w.bucket !== filters.duration) return false;
      if (filters.zone !== 'all' && String(w.zone) !== filters.zone) return false;
      return true;
    });
    libraryCount.textContent = `${matches.length} of ${LIB.length}`;
    if (matches.length === 0) {
      libraryList.innerHTML = `<li class="empty" style="grid-column: 1 / -1;">No sessions match those filters. Try widening one.</li>`;
      return;
    }
    libraryList.innerHTML = matches
      .map((w) => {
        const idx = LIB.indexOf(w);
        const min = Math.round(w.durationSec / 60);
        const bucketLabel = w.bucket === 'short' ? '< 30 min' : w.bucket === 'mid' ? '30 – 60 min' : '> 60 min';
        return `
          <li class="panel" style="display: flex; flex-direction: column; gap: 0;">
            <div style="padding: 14px 16px; display: flex; flex-direction: column; gap: 8px; flex: 1;">
              <div class="row" style="gap: 8px; flex-wrap: wrap;">
                <span class="chip chip-muted">${escape(w.sport)}</span>
                <span class="chip chip-soft">Z${w.zone}</span>
                <span class="metric-label row-end">${min} min</span>
              </div>
              <strong style="font-size: 15px;">${escape(w.name)}</strong>
              <p class="caption" style="margin: 0;">${escape(w.description)}</p>
              <p class="caption" style="margin: 0; font-family: var(--font-mono);">${escape(bucketLabel)}</p>
            </div>
            <div class="row" style="padding: 8px 12px; gap: 6px; border-top: 1px solid var(--border);">
              <button data-add="${idx}" type="button" class="btn btn-primary btn-sm">Add to my workouts</button>
              <button data-schedule="${idx}" type="button" class="btn btn-secondary btn-sm row-end">Schedule</button>
            </div>
          </li>
        `;
      })
      .join('');
  }
  renderLibrary();

  libraryList.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLButtonElement;
    const addIdx = t.dataset.add;
    const schedIdx = t.dataset.schedule;
    const idx = addIdx ?? schedIdx;
    if (idx == null) return;
    const w = LIB[Number(idx)]!;

    if (schedIdx != null) {
      // Save first, then jump to calendar with the new workout id.
      t.disabled = true;
      const id = await postWorkout(w);
      if (id) window.location.href = `/calendar?workout=${id}`;
      else t.disabled = false;
      return;
    }

    t.disabled = true;
    const original = t.textContent;
    t.textContent = 'Adding…';
    const id = await postWorkout(w);
    if (id) {
      t.textContent = 'Added ✓';
      await loadList();
    } else {
      t.textContent = original ?? 'Add';
      t.disabled = false;
    }
  });

  async function postWorkout(w: WorkoutDef): Promise<string | null> {
    try {
      const r = await fetch('/api/v1/workouts', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: w.name,
          description: w.description,
          sport: w.sport,
          steps: w.steps,
        }),
      });
      if (!r.ok) return null;
      const body = (await r.json()) as { id: string };
      return body.id;
    } catch {
      return null;
    }
  }

  // ------------- custom builder + saved list (existing) ----------------
  const stepList = document.getElementById('step-list')!;
  const workoutList = document.getElementById('workout-list')!;
  const status = document.getElementById('save-status')!;
  const form = document.getElementById('new-workout') as HTMLFormElement;
  const addStepBtn = document.getElementById('add-step')!;

  const steps: Step[] = [];
  addStep();
  void loadList();

  addStepBtn.addEventListener('click', () => addStep());

  function addStep() {
    steps.push({ kind: 'work', durationSec: 300 });
    renderSteps();
  }

  function renderSteps() {
    stepList.innerHTML = '';
    steps.forEach((step, i) => {
      const li = document.createElement('li');
      li.className = 'panel';
      li.innerHTML = `
        <div style="padding: 12px 14px; display: grid; grid-template-columns: 110px 110px 110px 80px 80px auto; gap: 8px; align-items: end;">
          <div class="field"><span class="caption">kind</span>
            <select class="select" data-i="${i}" data-f="kind">
              ${(['warmup', 'work', 'recover', 'cooldown', 'rest'] as StepKind[])
                .map((k) => `<option value="${k}" ${k === step.kind ? 'selected' : ''}>${k}</option>`)
                .join('')}
            </select>
          </div>
          <div class="field"><span class="caption">duration (s)</span>
            <input class="input mono" data-i="${i}" data-f="duration" type="number" value="${step.durationSec}" />
          </div>
          <div class="field"><span class="caption">target</span>
            <select class="select" data-i="${i}" data-f="targetType">
              <option value="" ${!step.target ? 'selected' : ''}>—</option>
              <option value="ftp_pct" ${step.target?.type === 'ftp_pct' ? 'selected' : ''}>%FTP</option>
              <option value="hr_pct" ${step.target?.type === 'hr_pct' ? 'selected' : ''}>%HRmax</option>
            </select>
          </div>
          <div class="field"><span class="caption">low</span>
            <input class="input mono" data-i="${i}" data-f="low" type="number" value="${step.target?.low ?? ''}" />
          </div>
          <div class="field"><span class="caption">high</span>
            <input class="input mono" data-i="${i}" data-f="high" type="number" value="${step.target?.high ?? ''}" />
          </div>
          <button type="button" data-remove="${i}" class="btn btn-ghost btn-sm" style="color: var(--danger);">Remove</button>
        </div>
      `;
      stepList.appendChild(li);
    });
  }

  stepList.addEventListener('change', (ev) => {
    const t = ev.target as HTMLInputElement | HTMLSelectElement;
    const i = Number(t.dataset.i);
    if (Number.isNaN(i)) return;
    const step = steps[i]!;
    const f = t.dataset.f;
    if (f === 'kind') step.kind = t.value as StepKind;
    if (f === 'duration') step.durationSec = Math.max(0, Number(t.value) || 0);
    if (f === 'targetType') {
      if (!t.value) step.target = undefined;
      else step.target = { type: t.value as 'ftp_pct' | 'hr_pct', low: 0, high: 0 };
    }
    if (f === 'low' || f === 'high') {
      if (!step.target) step.target = { type: 'ftp_pct', low: 0, high: 0 };
      step.target[f as 'low' | 'high'] = Number(t.value) || 0;
    }
  });

  stepList.addEventListener('click', (ev) => {
    const t = ev.target as HTMLElement;
    const idx = t.dataset.remove;
    if (idx == null) return;
    steps.splice(Number(idx), 1);
    renderSteps();
  });

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const fd = new FormData(form);
    const payload = {
      name: String(fd.get('name') ?? ''),
      sport: String(fd.get('sport') ?? 'cycling'),
      steps,
    };
    const r = await fetch('/api/v1/workouts', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (r.ok) {
      const body = (await r.json()) as { id: string; estimatedTss: number | null };
      status.textContent = `Saved · est ${body.estimatedTss?.toFixed(0) ?? '—'} TSS`;
      form.reset();
      steps.length = 0;
      addStep();
      await loadList();
    } else {
      status.textContent = `Couldn't save · HTTP ${r.status}`;
    }
  });

  async function loadList() {
    const r = await fetch('/api/v1/workouts', { credentials: 'include' });
    if (!r.ok) {
      workoutList.innerHTML = `<li class="empty">Sign in to save workouts.</li>`;
      return;
    }
    const body = (await r.json()) as {
      items: {
        id: string;
        name: string;
        sport: string;
        estimatedTss: number | null;
        estimatedDurationSec: number | null;
      }[];
    };
    workoutList.innerHTML = '';
    if (body.items.length === 0) {
      workoutList.innerHTML = `<li class="empty">No saved workouts yet. Add one from the library above.</li>`;
      return;
    }
    for (const w of body.items) {
      const li = document.createElement('li');
      li.className = 'panel';
      const dur = w.estimatedDurationSec ? `${Math.round(w.estimatedDurationSec / 60)} min` : '—';
      const tss = w.estimatedTss != null ? `${w.estimatedTss.toFixed(0)} TSS` : '—';
      li.innerHTML = `
        <div style="padding: 14px 20px; display: flex; align-items: center; gap: 12px;">
          <div style="flex: 1;">
            <strong style="font-size: 15px;">${escape(w.name)}</strong>
            <p class="caption" style="margin-top: 2px;">${escape(w.sport)} · ${dur} · ${tss}</p>
          </div>
          <a class="btn btn-secondary btn-sm" href="/api/v1/workouts/${escape(w.id)}/export.fit">FIT</a>
          <a class="btn btn-secondary btn-sm" href="/api/v1/workouts/${escape(w.id)}/export.zwo">ZWO</a>
          <button data-del="${escape(w.id)}" class="btn btn-ghost btn-sm" style="color: var(--danger);">Delete</button>
        </div>
      `;
      workoutList.appendChild(li);
    }
  }

  workoutList.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement;
    const id = t.dataset.del;
    if (!id) return;
    const r = await fetch(`/api/v1/workouts/${id}`, { method: 'DELETE', credentials: 'include' });
    if (r.ok) await loadList();
  });

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  // ── CSV tab ──────────────────────────────────────────────────────────────
  const entryMode = document.getElementById('entry-mode') as HTMLElement;
  const newWorkoutForm = document.getElementById('new-workout') as HTMLFormElement;
  const csvPanel = document.getElementById('csv-panel') as HTMLElement;
  const csvInput = document.getElementById('csv-input') as HTMLTextAreaElement;
  const csvPreview = document.getElementById('csv-preview') as HTMLElement;
  const csvPreviewList = document.getElementById('csv-preview-list') as HTMLElement;
  const csvError = document.getElementById('csv-error') as HTMLElement;
  const csvSaveBtn = document.getElementById('csv-save') as HTMLButtonElement;
  const csvSaveStatus = document.getElementById('csv-save-status') as HTMLElement;

  entryMode?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-v]') as HTMLButtonElement | null;
    if (!btn) return;
    entryMode.querySelectorAll('button').forEach((b) => b.classList.remove('on'));
    btn.classList.add('on');
    const mode = btn.dataset['v'];
    newWorkoutForm.style.display = mode === 'steps' ? '' : 'none';
    csvPanel.style.display = mode === 'csv' ? '' : 'none';
  });

  function formatTarget(t: { type: string; low: number; high: number }): string {
    const range = t.low === t.high ? `${t.low}` : `${t.low}–${t.high}`;
    if (t.type === 'watts') return `${range}W`;
    if (t.type === 'ftp_pct') return `${range}% FTP`;
    if (t.type === 'hr_bpm') return `${range} bpm`;
    if (t.type === 'pace') {
      const fmt = (s: number) => `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
      return t.low === t.high ? `${fmt(t.low)}/km` : `${fmt(t.low)}–${fmt(t.high)}/km`;
    }
    return range;
  }

  function updateCsvPreview() {
    const text = csvInput?.value.trim() ?? '';
    if (!text) {
      csvPreview.style.display = 'none';
      csvError.style.display = 'none';
      return;
    }
    try {
      const parsed = parseWorkoutCsv(text);
      csvError.style.display = 'none';
      csvPreviewList.innerHTML = parsed.steps
        .map((s) => {
          const durMin = (s.durationSec / 60).toFixed(0);
          const target = s.target ? ` — ${formatTarget(s.target)}` : '';
          return `<li style="padding: 3px 0;">${s.kind} &nbsp; ${durMin}min${target}</li>`;
        })
        .join('');
      csvPreview.style.display = '';
    } catch (e) {
      csvPreview.style.display = 'none';
      csvError.textContent = e instanceof WorkoutCsvError ? e.message : 'Parse error';
      csvError.style.display = '';
    }
  }

  csvInput?.addEventListener('input', updateCsvPreview);

  csvSaveBtn?.addEventListener('click', async () => {
    const text = csvInput?.value.trim() ?? '';
    if (!text) return;
    try {
      parseWorkoutCsv(text);
    } catch (e) {
      csvError.textContent = e instanceof WorkoutCsvError ? e.message : 'Parse error';
      csvError.style.display = '';
      return;
    }
    csvSaveBtn.disabled = true;
    csvSaveStatus.textContent = 'Saving…';
    const res = await fetch('/api/v1/workouts', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ csvText: text }),
    });
    csvSaveBtn.disabled = false;
    if (res.ok) {
      csvSaveStatus.textContent = 'Saved!';
      csvError.style.display = 'none';
      if (csvInput) csvInput.value = '';
      csvPreview.style.display = 'none';
      await loadList();
      setTimeout(() => { csvSaveStatus.textContent = ''; }, 2000);
    } else {
      const msg = await res.text();
      csvError.textContent = msg || 'Save failed';
      csvError.style.display = '';
      csvSaveStatus.textContent = '';
    }
  });
</script>

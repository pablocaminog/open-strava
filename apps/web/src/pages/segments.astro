---
import Shell from '../layouts/Shell.astro';
import Icon from '../components/Icon.astro';
---

<Shell title="Segments" active="segments">
  <div class="stack" style="gap: 20px;">
    <header>
      <h1 class="h1" style="font-size: 28px;">Segments</h1>
      <p class="muted body-sm" style="margin-top: 4px;">
        Search by bounding box. Format <code>minLat,minLng,maxLat,maxLng</code> — for example
        <code>59.30,18.00,59.40,18.20</code> for central Stockholm.
      </p>
    </header>

    <div class="panel">
      <div class="panel-body">
        <form id="seg-form" class="row" style="gap: 8px;">
          <input
            class="input"
            name="bbox"
            required
            placeholder="59.30,18.00,59.40,18.20"
            style="font-family: var(--font-mono); flex: 1;"
          />
          <button type="submit" class="btn btn-primary">
            <Icon name="search" size={14} /> Search
          </button>
        </form>
      </div>
    </div>

    <ul id="seg-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 12px;"></ul>
  </div>
</Shell>

<script>
  const form = document.getElementById('seg-form') as HTMLFormElement;
  const list = document.getElementById('seg-list')!;
  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const bbox = String(new FormData(form).get('bbox'));
    list.innerHTML = `<li class="caption">Searching…</li>`;
    const r = await fetch(`/api/v1/segments?bbox=${encodeURIComponent(bbox)}`, {
      credentials: 'include',
    });
    if (!r.ok) {
      list.innerHTML = `<li class="caption" style="color: var(--danger);">Couldn't search · HTTP ${r.status}</li>`;
      return;
    }
    const body = (await r.json()) as {
      items: { id: string; name: string; sport: string; distanceM: number }[];
    };
    list.innerHTML = '';
    if (body.items.length === 0) {
      list.innerHTML = `<li class="empty">No segments inside that box. Try widening it.</li>`;
      return;
    }
    for (const s of body.items) {
      const li = document.createElement('li');
      li.className = 'panel';
      li.innerHTML = `
        <a href="/segments/${escape(s.id)}" style="display: flex; align-items: center; gap: 16px; padding: 16px 20px;">
          <div style="flex: 1;">
            <div class="row" style="gap: 10px;">
              <strong style="font-size: 16px;">${escape(s.name)}</strong>
              <span class="chip chip-muted">${escape(s.sport)}</span>
            </div>
            <p class="caption" style="margin-top: 4px;">${(s.distanceM / 1000).toFixed(2)} km</p>
          </div>
          <span class="metric-label">view</span>
        </a>
      `;
      list.appendChild(li);
    }
  });
  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>

---
import Shell from '../layouts/Shell.astro';
import Icon from '../components/Icon.astro';
---

<Shell title="Clubs" active="clubs">
  <div class="stack" style="gap: 20px;">
    <header>
      <h1 class="h1" style="font-size: 28px;">Clubs</h1>
      <p class="muted body-sm" style="margin-top: 4px;">Find a group ride. Or start your own.</p>
    </header>

    <ul id="club-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 12px;"></ul>

    <details class="panel">
      <summary style="cursor: pointer; padding: 14px 20px; display: flex; align-items: center; gap: 8px; font-weight: 500;">
        <Icon name="plus" size={16} /> Create a club
      </summary>
      <form id="new-club" class="panel-body stack" style="gap: 10px;">
        <div class="field">
          <label class="field-label">Name</label>
          <input class="input" name="name" required />
        </div>
        <div class="field">
          <label class="field-label">Description</label>
          <textarea class="textarea" name="description"></textarea>
        </div>
        <button class="btn btn-primary" style="align-self: flex-start;" type="submit">Create</button>
      </form>
    </details>
  </div>
</Shell>

<script>
  const list = document.getElementById('club-list')!;

  load();
  (document.getElementById('new-club') as HTMLFormElement).addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const fd = new FormData(ev.target as HTMLFormElement);
    const r = await fetch('/api/v1/clubs', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: fd.get('name'), description: fd.get('description') }),
    });
    if (r.ok) await load();
  });

  async function load() {
    const r = await fetch('/api/v1/clubs', { credentials: 'include' });
    if (!r.ok) {
      list.innerHTML = `<li class="empty">Sign in to see clubs.</li>`;
      return;
    }
    const body = (await r.json()) as {
      items: { id: string; name: string; sportFocus: string | null }[];
    };
    list.innerHTML = '';
    if (body.items.length === 0) {
      list.innerHTML = `<li class="empty">No public clubs yet — create one above.</li>`;
      return;
    }
    for (const c of body.items) {
      const li = document.createElement('li');
      li.className = 'panel';
      li.innerHTML = `
        <a href="/clubs/${escape(c.id)}" style="display: flex; align-items: center; gap: 16px; padding: 14px 20px;">
          <strong style="flex: 1; font-size: 15px;">${escape(c.name)}</strong>
          ${c.sportFocus ? `<span class="chip chip-muted">${escape(c.sportFocus)}</span>` : ''}
          <span class="metric-label">view</span>
        </a>
      `;
      list.appendChild(li);
    }
  }
  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>

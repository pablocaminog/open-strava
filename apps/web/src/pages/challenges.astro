---
import Shell from '../layouts/Shell.astro';
import Icon from '../components/Icon.astro';
---

<Shell title="Challenges" active="challenges">
  <div class="stack" style="gap: 20px;">
    <header>
      <h1 class="h1" style="font-size: 28px;">Challenges</h1>
      <p class="muted body-sm" style="margin-top: 4px;">
        Set a goal — distance, climbing, time, or TSS — over a date range. Auto-progresses as
        activities ingest.
      </p>
    </header>

    <details class="panel">
      <summary style="cursor: pointer; padding: 14px 20px; display: flex; align-items: center; gap: 8px; font-weight: 500;">
        <Icon name="plus" size={16} /> Create a challenge
      </summary>
      <form id="new-challenge" class="panel-body grid-tiles grid-cols-2" style="gap: 12px;">
        <div class="field" style="grid-column: span 2;">
          <label class="field-label">Name</label>
          <input class="input" name="name" required />
        </div>
        <div class="field" style="grid-column: span 2;">
          <label class="field-label">Description</label>
          <textarea class="textarea" name="description"></textarea>
        </div>
        <div class="field">
          <label class="field-label">Metric</label>
          <select class="select" name="metric">
            <option value="distance_m">Distance (m)</option>
            <option value="ascent_m">Ascent (m)</option>
            <option value="total_seconds">Time (s)</option>
            <option value="tss">TSS</option>
          </select>
        </div>
        <div class="field">
          <label class="field-label">Goal</label>
          <input class="input mono" type="number" name="goal" required min="1" />
        </div>
        <div class="field">
          <label class="field-label">Sport (optional)</label>
          <input class="input" name="sport" placeholder="e.g. cycling" />
        </div>
        <div class="field">
          <label class="field-label">Visibility</label>
          <select class="select" name="visibility">
            <option value="public">Public</option>
            <option value="private">Private</option>
          </select>
        </div>
        <div class="field">
          <label class="field-label">Starts</label>
          <input class="input mono" type="date" name="startsAt" required />
        </div>
        <div class="field">
          <label class="field-label">Ends</label>
          <input class="input mono" type="date" name="endsAt" required />
        </div>
        <button class="btn btn-primary" style="grid-column: span 2; justify-self: flex-start;" type="submit">
          Create challenge
        </button>
      </form>
    </details>

    <section class="stack" style="gap: 12px;">
      <h2 class="h3" style="font-size: 18px;">Your challenges</h2>
      <ul
        id="my-challenges"
        class="stack"
        style="list-style: none; margin: 0; padding: 0; gap: 10px;"
      ></ul>
    </section>

    <section class="stack" style="gap: 12px;">
      <h2 class="h3" style="font-size: 18px;">All public challenges</h2>
      <ul id="challenge-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 10px;"></ul>
    </section>
    <div id="leaderboard"></div>
  </div>
</Shell>

<script>
  const list = document.getElementById('challenge-list')!;
  const lb = document.getElementById('leaderboard')!;
  const form = document.getElementById('new-challenge') as HTMLFormElement;

  void load();
  void loadMine();

  async function load() {
    const r = await fetch('/api/v1/challenges', { credentials: 'include' });
    if (!r.ok) {
      list.innerHTML = `<li class="empty">Sign in to see challenges.</li>`;
      return;
    }
    const body = (await r.json()) as {
      items: {
        id: string;
        name: string;
        metric: string;
        goal: number;
        sport: string | null;
        startsAt: number;
        endsAt: number;
        joined?: number;
      }[];
    };
    list.innerHTML = '';
    if (body.items.length === 0) {
      list.innerHTML = `<li class="empty">No challenges yet — create one above.</li>`;
      return;
    }
    for (const ch of body.items) {
      const li = document.createElement('li');
      li.className = 'panel';
      const isJoined = ch.joined === 1;
      li.innerHTML = `
        <div style="padding: 14px 20px; display: flex; align-items: center; gap: 12px;">
          <div style="flex: 1;">
            <div class="row" style="gap: 10px; flex-wrap: wrap;">
              <strong style="font-size: 15px;">${escape(ch.name)}</strong>
              ${isJoined ? `<span class="chip chip-success">joined</span>` : ''}
              ${ch.sport ? `<span class="chip chip-muted">${escape(ch.sport)}</span>` : ''}
            </div>
            <p class="caption" style="margin-top: 4px; font-family: var(--font-mono);">
              ${escape(formatGoal(ch.metric, ch.goal))} ·
              ${fmt(ch.startsAt)} → ${fmt(ch.endsAt)}
            </p>
          </div>
          ${
            isJoined
              ? `<button data-leave="${escape(ch.id)}" class="btn btn-ghost btn-sm" style="color: var(--danger);">Leave</button>`
              : `<button data-join="${escape(ch.id)}" class="btn btn-primary btn-sm">Join</button>`
          }
          <button data-board="${escape(ch.id)}" class="btn btn-secondary btn-sm">Board</button>
        </div>
      `;
      list.appendChild(li);
    }
  }

  const myList = document.getElementById('my-challenges')!;
  async function loadMine() {
    const r = await fetch('/api/v1/me/challenges', { credentials: 'include' });
    if (!r.ok) {
      myList.innerHTML = `<li class="empty">Sign in to track your challenges.</li>`;
      return;
    }
    const body = (await r.json()) as {
      items: {
        id: string;
        name: string;
        metric: string;
        goal: number;
        sport: string | null;
        startsAt: number;
        endsAt: number;
        progress: number;
        pct: number;
      }[];
    };
    if (body.items.length === 0) {
      myList.innerHTML = `<li class="empty">You haven't joined any challenges yet. Pick one below.</li>`;
      return;
    }
    myList.innerHTML = body.items
      .map((ch) => {
        const goalStr = formatGoal(ch.metric, ch.goal);
        const progStr = formatGoal(ch.metric, ch.progress);
        const pct = Math.max(0, Math.min(100, ch.pct));
        return `
          <li class="panel">
            <div style="padding: 14px 20px; display: flex; flex-direction: column; gap: 10px;">
              <div class="row" style="gap: 10px; flex-wrap: wrap;">
                <strong style="font-size: 15px;">${escape(ch.name)}</strong>
                ${ch.sport ? `<span class="chip chip-muted">${escape(ch.sport)}</span>` : ''}
                <span class="row-end caption" style="font-family: var(--font-mono);">
                  ${fmt(ch.startsAt)} → ${fmt(ch.endsAt)}
                </span>
              </div>
              <div class="row" style="gap: 12px; align-items: baseline; font-family: var(--font-mono); font-size: 13px;">
                <span class="metric-md">${escape(progStr)}</span>
                <span class="caption">/ ${escape(goalStr)}</span>
                <span class="row-end" style="font-weight: 600;">${pct.toFixed(1)}%</span>
              </div>
              <div style="height: 8px; border-radius: 9999px; background: var(--ink-100); overflow: hidden;">
                <div style="height: 100%; width: ${pct}%; background: var(--pace-500); transition: width 220ms var(--ease-out);"></div>
              </div>
              <div class="row" style="gap: 8px;">
                <button data-board="${escape(ch.id)}" class="btn btn-secondary btn-sm">Leaderboard</button>
                <button data-leave="${escape(ch.id)}" class="btn btn-ghost btn-sm" style="margin-left: auto; color: var(--danger);">Leave</button>
              </div>
            </div>
          </li>
        `;
      })
      .join('');
  }

  myList.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement;
    if (t.dataset.leave) {
      const r = await fetch(`/api/v1/challenges/${t.dataset.leave}/join`, {
        method: 'DELETE',
        credentials: 'include',
      });
      if (r.ok) {
        await loadMine();
        await load();
      }
    } else if (t.dataset.board) {
      await fetchBoard(t.dataset.board);
    }
  });

  function formatGoal(metric: string, value: number): string {
    if (metric === 'distance_m') return `${(value / 1000).toFixed(1)} km`;
    if (metric === 'ascent_m') return `${Math.round(value).toLocaleString()} m`;
    if (metric === 'total_seconds') {
      const h = Math.floor(value / 3600);
      return `${h.toLocaleString()} h`;
    }
    if (metric === 'tss') return `${Math.round(value).toLocaleString()} TSS`;
    return String(value);
  }

  async function fetchBoard(id: string) {
    const r = await fetch(`/api/v1/challenges/${id}/leaderboard`, {
      credentials: 'include',
    });
    if (!r.ok) return;
    const body = (await r.json()) as {
      items: { athleteId: string; handle: string; total: number }[];
    };
    lb.innerHTML = `
      <div class="panel" style="margin-top: 8px;">
        <div class="panel-header"><h3 class="h3" style="font-size: 16px;">Leaderboard</h3></div>
        <table class="lb">
          <thead><tr><th style="width: 60px;">Rank</th><th>Athlete</th><th>Total</th></tr></thead>
          <tbody>
            ${body.items
              .map(
                (row, i) => `
              <tr>
                <td class="num">${i + 1}</td>
                <td>${escape(row.handle ?? '?')}</td>
                <td class="num">${row.total.toFixed(1)}</td>
              </tr>`,
              )
              .join('')}
          </tbody>
        </table>
      </div>`;
  }

  list.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement;
    if (t.dataset.join) {
      const r = await fetch(`/api/v1/challenges/${t.dataset.join}/join`, {
        method: 'POST',
        credentials: 'include',
      });
      if (r.ok) {
        await load();
        await loadMine();
      }
    } else if (t.dataset.leave) {
      const r = await fetch(`/api/v1/challenges/${t.dataset.leave}/join`, {
        method: 'DELETE',
        credentials: 'include',
      });
      if (r.ok) {
        await load();
        await loadMine();
      }
    } else if (t.dataset.board) {
      await fetchBoard(t.dataset.board);
    }
  });

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const fd = new FormData(form);
    const payload = {
      name: String(fd.get('name') ?? ''),
      description: String(fd.get('description') ?? ''),
      metric: String(fd.get('metric') ?? 'distance_m'),
      goal: Number(fd.get('goal') ?? 0),
      sport: String(fd.get('sport') ?? '') || null,
      visibility: String(fd.get('visibility') ?? 'public'),
      startsAt: String(fd.get('startsAt') ?? ''),
      endsAt: String(fd.get('endsAt') ?? ''),
    };
    const r = await fetch('/api/v1/challenges', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (r.ok) {
      form.reset();
      await load();
    }
  });

  function fmt(ts: number) {
    return new Date(ts * 1000).toISOString().slice(0, 10);
  }
  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>

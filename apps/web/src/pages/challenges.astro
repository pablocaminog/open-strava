---
import Base from '../layouts/Base.astro';
---

<Base title="Challenges · pacelore">
  <section class="space-y-6">
    <h1 class="text-2xl font-bold">Challenges</h1>
    <p class="text-sm text-neutral-600 dark:text-neutral-400">
      Set a goal — distance, climbing, time, or TSS — over a date range. Public challenges anyone
      can join.
    </p>

    <details class="rounded border border-neutral-200 p-3 dark:border-neutral-800">
      <summary class="cursor-pointer font-medium">Create a challenge</summary>
      <form id="new-challenge" class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-2">
        <label class="text-sm sm:col-span-2">Name
          <input
            name="name"
            required
            class="mt-1 w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900"
          />
        </label>
        <label class="text-sm sm:col-span-2">Description
          <textarea
            name="description"
            class="mt-1 w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900"
          ></textarea>
        </label>
        <label class="text-sm">Metric
          <select
            name="metric"
            class="mt-1 w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900"
          >
            <option value="distance_m">Distance (m)</option>
            <option value="ascent_m">Ascent (m)</option>
            <option value="total_seconds">Time (s)</option>
            <option value="tss">TSS</option>
          </select>
        </label>
        <label class="text-sm">Goal
          <input
            type="number"
            name="goal"
            required
            min="1"
            class="mt-1 w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900"
          />
        </label>
        <label class="text-sm">Sport (optional)
          <input
            name="sport"
            placeholder="e.g. cycling"
            class="mt-1 w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900"
          />
        </label>
        <label class="text-sm">Visibility
          <select
            name="visibility"
            class="mt-1 w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900"
          >
            <option value="public">Public</option>
            <option value="private">Private</option>
          </select>
        </label>
        <label class="text-sm">Starts
          <input
            type="date"
            name="startsAt"
            required
            class="mt-1 w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900"
          />
        </label>
        <label class="text-sm">Ends
          <input
            type="date"
            name="endsAt"
            required
            class="mt-1 w-full rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700 dark:bg-neutral-900"
          />
        </label>
        <button class="rounded bg-accent px-3 py-1.5 text-sm font-medium text-white sm:col-span-2"
          >Create</button
        >
      </form>
    </details>

    <ul id="challenge-list" class="space-y-2"></ul>
    <div id="leaderboard"></div>
  </section>
</Base>

<script>
  const list = document.getElementById('challenge-list')!;
  const lb = document.getElementById('leaderboard')!;
  const form = document.getElementById('new-challenge') as HTMLFormElement;

  void load();

  async function load() {
    const r = await fetch('/api/v1/challenges', { credentials: 'include' });
    if (!r.ok) {
      list.innerHTML =
        '<li class="text-sm text-neutral-500">Please <a class="text-accent hover:underline" href="/login">log in</a>.</li>';
      return;
    }
    const body = (await r.json()) as {
      items: {
        id: string;
        name: string;
        metric: string;
        goal: number;
        sport: string | null;
        startsAt: number;
        endsAt: number;
      }[];
    };
    list.innerHTML = '';
    for (const ch of body.items) {
      const li = document.createElement('li');
      li.className = 'rounded border border-neutral-200 p-3 dark:border-neutral-800';
      li.innerHTML = `
        <div class="flex items-center justify-between">
          <div>
            <p class="font-medium">${escape(ch.name)}</p>
            <p class="text-xs text-neutral-500">
              ${ch.metric} ≥ ${ch.goal}${ch.sport ? ' · ' + ch.sport : ''} ·
              ${fmt(ch.startsAt)} → ${fmt(ch.endsAt)}
            </p>
          </div>
          <div class="flex gap-2 text-xs">
            <button data-join="${ch.id}" class="rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700">Join</button>
            <button data-board="${ch.id}" class="rounded border border-neutral-300 px-2 py-1 dark:border-neutral-700">Board</button>
          </div>
        </div>
      `;
      list.appendChild(li);
    }
  }

  list.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement;
    if (t.dataset.join) {
      const r = await fetch(`/api/v1/challenges/${t.dataset.join}/join`, {
        method: 'POST',
        credentials: 'include',
      });
      if (r.ok) (t as HTMLButtonElement).textContent = 'Joined ✓';
    } else if (t.dataset.board) {
      const r = await fetch(`/api/v1/challenges/${t.dataset.board}/leaderboard`, {
        credentials: 'include',
      });
      if (!r.ok) return;
      const body = (await r.json()) as {
        items: { athleteId: string; handle: string; total: number }[];
      };
      lb.innerHTML = `<h2 class="mt-4 text-lg font-semibold">Leaderboard</h2><ol class="mt-2 space-y-1 text-sm">${body.items
        .map(
          (row, i) =>
            `<li><span class="text-xs text-neutral-500">#${i + 1}</span> <strong>${escape(row.handle ?? '?')}</strong> · ${row.total.toFixed(1)}</li>`,
        )
        .join('')}</ol>`;
    }
  });

  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const fd = new FormData(form);
    const payload = {
      name: String(fd.get('name') ?? ''),
      description: String(fd.get('description') ?? ''),
      metric: String(fd.get('metric') ?? 'distance_m'),
      goal: Number(fd.get('goal') ?? 0),
      sport: String(fd.get('sport') ?? '') || null,
      visibility: String(fd.get('visibility') ?? 'public'),
      startsAt: String(fd.get('startsAt') ?? ''),
      endsAt: String(fd.get('endsAt') ?? ''),
    };
    const r = await fetch('/api/v1/challenges', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (r.ok) {
      form.reset();
      await load();
    }
  });

  function fmt(ts: number): string {
    return new Date(ts * 1000).toISOString().slice(0, 10);
  }
  function escape(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
</script>

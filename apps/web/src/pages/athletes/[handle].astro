---
import Shell from '../../layouts/Shell.astro';
const { handle } = Astro.params;
---

<Shell title={`@${handle}`}>
  <div class="stack" style="gap: 20px;">
    <header id="profile-header" class="stack" style="gap: 8px;">
      <h1 class="h1">Loading…</h1>
    </header>

    <div class="panel">
      <div class="panel-header"><h3 class="h3" style="font-size: 16px;">Activities</h3></div>
      <ul id="profile-activities" class="stack" style="list-style: none; margin: 0; padding: 0;"></ul>
    </div>
  </div>
</Shell>

<script define:vars={{ handle }}>
  window.__PACELORE_HANDLE__ = handle;
</script>

<script>
  type ProfileResponse = {
    athlete: {
      id: string;
      handle: string;
      displayName: string | null;
      bio: string | null;
      location: string | null;
      createdAt: number;
    };
    counts: { followers: number; following: number; activities: number };
    isSelf: boolean;
    isFollowing: boolean;
  };

  type Activity = {
    id: string;
    sport: string;
    name: string | null;
    startedAt: number;
    totalSeconds: number;
    distanceM: number | null;
    tss: number | null;
  };

  const handle = (window as unknown as { __PACELORE_HANDLE__: string }).__PACELORE_HANDLE__;
  const header = document.getElementById('profile-header')!;
  const list = document.getElementById('profile-activities')!;

  init().catch(
    (err) =>
      (header.innerHTML = `<h1 class="h1">Couldn't load profile</h1><p class="caption">${(err as Error).message}</p>`),
  );

  async function init() {
    const r = await fetch(`/api/v1/athletes/by-handle/${encodeURIComponent(handle)}`, {
      credentials: 'include',
    });
    if (r.status === 401) {
      header.innerHTML = `<h1 class="h1">Sign in required</h1><p class="caption">Sign in to view this profile — <a href="/login" style="color: var(--fg); text-decoration: underline;">go to sign in</a>.</p>`;
      return;
    }
    if (!r.ok) {
      header.innerHTML = `<h1 class="h1">Athlete not found</h1>`;
      return;
    }
    const profile = (await r.json()) as ProfileResponse;
    renderHeader(profile);
    await loadActivities(profile.athlete.id);
  }

  function renderHeader(p: ProfileResponse) {
    const display = p.athlete.displayName ?? p.athlete.handle;
    const initials = display
      .split(/[\s_-]+/)
      .filter(Boolean)
      .slice(0, 2)
      .map((s) => s[0]?.toUpperCase() ?? '')
      .join('') || display.slice(0, 2).toUpperCase();
    const color = ((hash(p.athlete.handle) % 5) + 1) as 1 | 2 | 3 | 4 | 5;

    const followBtn = p.isSelf
      ? ''
      : `<button id="follow-btn" data-following="${p.isFollowing}" class="btn ${p.isFollowing ? 'btn-secondary' : 'btn-primary'} btn-sm">${
          p.isFollowing ? 'Unfollow' : 'Follow'
        }</button>`;
    header.innerHTML = `
      <div style="display: flex; align-items: center; gap: 16px;">
        <span class="avatar lg" data-color="${color}"><span>${escape(initials)}</span></span>
        <div style="flex: 1;">
          <h1 class="h1">${escape(display)}</h1>
          <p class="caption" style="font-family: var(--font-mono);">@${escape(p.athlete.handle)}</p>
        </div>
        ${followBtn}
      </div>
      ${p.athlete.bio ? `<p class="body" style="max-width: 60ch;">${escape(p.athlete.bio)}</p>` : ''}
      ${p.athlete.location ? `<p class="caption">${escape(p.athlete.location)}</p>` : ''}
      <div class="row" style="gap: 24px; padding-top: 4px;">
        <span class="metric-sm"><strong>${p.counts.activities}</strong> <span class="metric-label" style="display: inline;">activities</span></span>
        <span class="metric-sm"><strong>${p.counts.followers}</strong> <span class="metric-label" style="display: inline;">followers</span></span>
        <span class="metric-sm"><strong>${p.counts.following}</strong> <span class="metric-label" style="display: inline;">following</span></span>
      </div>
    `;
    if (!p.isSelf) wireFollowButton(p.athlete.id);
  }

  function wireFollowButton(athleteId: string) {
    const btn = document.getElementById('follow-btn') as HTMLButtonElement | null;
    if (!btn) return;
    btn.addEventListener('click', async () => {
      btn.disabled = true;
      const isFollowing = btn.dataset.following === 'true';
      const method = isFollowing ? 'DELETE' : 'POST';
      const r = await fetch(`/api/v1/follows/${athleteId}`, { method, credentials: 'include' });
      if (r.ok) {
        const next = !isFollowing;
        btn.dataset.following = String(next);
        btn.textContent = next ? 'Unfollow' : 'Follow';
        btn.classList.toggle('btn-primary', !next);
        btn.classList.toggle('btn-secondary', next);
      }
      btn.disabled = false;
    });
  }

  async function loadActivities(id: string) {
    const r = await fetch(`/api/v1/athletes/${id}/activities`, { credentials: 'include' });
    if (!r.ok) return;
    const body = (await r.json()) as { items: Activity[] };
    list.innerHTML = '';
    if (body.items.length === 0) {
      list.innerHTML = `<li class="empty" style="margin: 16px;">No activities visible.</li>`;
      return;
    }
    for (const a of body.items) {
      const li = document.createElement('li');
      const date = new Date(a.startedAt * 1000).toLocaleDateString(undefined, {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
      });
      const dist = a.distanceM != null ? `${(a.distanceM / 1000).toFixed(1)} km` : '—';
      const dur = formatDuration(a.totalSeconds);
      const tss = a.tss != null ? a.tss.toFixed(0) : '—';
      li.innerHTML = `
        <a href="/activity/${escape(a.id)}" style="display: grid; grid-template-columns: 1fr 100px 120px 80px; gap: 16px; align-items: center; padding: 14px 20px; border-bottom: 1px solid var(--border);">
          <div>
            <strong style="font-size: 14px;">${escape(a.name ?? sentenceCase(a.sport))}</strong>
            <p class="caption" style="margin-top: 2px; font-family: var(--font-mono);">${escape(date)} · ${escape(a.sport)}</p>
          </div>
          <span class="metric-sm">${escape(dur)}</span>
          <span class="metric-sm">${escape(dist)}</span>
          <span class="metric-sm">${escape(tss)} TSS</span>
        </a>
      `;
      list.appendChild(li);
    }
  }

  function formatDuration(s: number) {
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    if (h === 0) return `${m}m`;
    return `${h}h ${String(m).padStart(2, '0')}m`;
  }

  function sentenceCase(s: string) {
    return s.charAt(0).toUpperCase() + s.slice(1);
  }

  function hash(s: string): number {
    let h = 0;
    for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
    return Math.abs(h);
  }

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>

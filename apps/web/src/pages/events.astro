---
import Shell from '../layouts/Shell.astro';
---

<Shell title="Events" active="events">
  <div class="stack" style="gap: 20px;">
    <header>
      <h1 class="h1" style="font-size: 28px;">Upcoming events</h1>
      <p class="muted body-sm" style="margin-top: 4px;">
        Group rides, races, training sessions. RSVP from a public page; .ics export available.
      </p>
    </header>

    <ul id="event-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 12px;"></ul>
  </div>
</Shell>

<script>
  const list = document.getElementById('event-list')!;
  fetch('/api/v1/events', { credentials: 'include' })
    .then((r) => (r.ok ? r.json() : null))
    .then((body) => {
      if (!body) {
        list.innerHTML = `<li class="empty">Sign in to see events.</li>`;
        return;
      }
      const items = (
        body as {
          items: {
            id: string;
            name: string;
            type: string;
            startsAt: number;
            location: string | null;
          }[];
        }
      ).items;
      list.innerHTML =
        items.length === 0 ? `<li class="empty">No upcoming events.</li>` : '';
      for (const e of items) {
        const li = document.createElement('li');
        li.className = 'panel';
        const when = new Date(e.startsAt * 1000).toLocaleString(undefined, {
          weekday: 'short',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit',
        });
        li.innerHTML = `
          <a href="/events/${escape(e.id)}" style="display: flex; align-items: center; gap: 16px; padding: 14px 20px;">
            <div style="flex: 1;">
              <div class="row" style="gap: 10px;">
                <strong style="font-size: 15px;">${escape(e.name)}</strong>
                <span class="chip chip-muted">${escape(e.type)}</span>
              </div>
              <p class="caption" style="margin-top: 4px; font-family: var(--font-mono);">
                ${escape(when)}${e.location ? ` · ${escape(e.location)}` : ''}
              </p>
            </div>
            <span class="metric-label">view</span>
          </a>
        `;
        list.appendChild(li);
      }
    });
  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }
</script>

---
import Shell from '../layouts/Shell.astro';
---

<Shell title="Training calendar" active="calendar">
  <div class="stack" style="gap: 20px;">
    <header>
      <h1 class="h1" style="font-size: 28px;">Training calendar</h1>
      <p id="calendar-subtitle" class="muted body-sm" style="margin-top: 4px;">Loading…</p>
    </header>

    <div class="panel">
      <div class="panel-header">
        <h3 class="h3" style="font-size: 16px;">Last 365 days</h3>
        <span id="day-detail" class="row-end caption" style="font-family: var(--font-mono);"></span>
      </div>
      <div class="panel-body" style="overflow-x: auto;">
        <div id="calendar-grid"></div>
      </div>
    </div>

    <div class="panel">
      <div class="panel-header">
        <h3 class="h3" style="font-size: 16px;">Plan upcoming</h3>
      </div>
      <div class="panel-body stack" style="gap: 16px;">
        <form id="schedule-form" class="grid-tiles" style="grid-template-columns: 1fr 1fr 2fr auto; gap: 12px; align-items: end;">
          <div class="field">
            <label class="field-label">Date</label>
            <input class="input" type="date" name="scheduledDate" required />
          </div>
          <div class="field">
            <label class="field-label">Workout</label>
            <select id="schedule-workout" class="select" name="workoutId"></select>
          </div>
          <div class="field">
            <label class="field-label">Notes</label>
            <input class="input" name="notes" placeholder="Optional" />
          </div>
          <button class="btn btn-primary" type="submit">Schedule</button>
        </form>

        <ul id="planned-list" class="stack" style="list-style: none; margin: 0; padding: 0; gap: 8px;"></ul>
      </div>
    </div>
  </div>
</Shell>

<script>
  type Day = { date: string; tss: number };

  const subtitle = document.getElementById('calendar-subtitle')!;
  const grid = document.getElementById('calendar-grid')!;
  const detail = document.getElementById('day-detail')!;

  init().catch((err) => {
    subtitle.textContent = `Couldn't load: ${(err as Error).message}`;
  });

  async function init() {
    const me = await fetch('/api/v1/auth/me', { credentials: 'include' });
    if (!me.ok) {
      subtitle.innerHTML = `Sign in to see your calendar — <a href="/login" style="color: var(--fg); text-decoration: underline;">go to sign in</a>.`;
      return;
    }
    const { user } = (await me.json()) as { user: { id: string; handle: string } };

    const to = isoToday();
    const from = isoDaysAgo(364);
    const pmc = await fetch(`/api/v1/athletes/${user.id}/pmc?from=${from}&to=${to}`, {
      credentials: 'include',
    });
    if (!pmc.ok) throw new Error(`pmc HTTP ${pmc.status}`);
    const { days } = (await pmc.json()) as { days: Day[] };

    const total = days.reduce((a, b) => a + b.tss, 0);
    const trainingDays = days.filter((d) => d.tss > 0).length;
    subtitle.textContent = `${user.handle} · last 365 days · ${trainingDays} training days · ${Math.round(
      total,
    )} total TSS`;

    grid.innerHTML = '';
    grid.appendChild(buildHeatmap(days));

    await loadWorkoutOptions();
    await loadPlanned();
  }

  async function loadWorkoutOptions() {
    const sel = document.getElementById('schedule-workout') as HTMLSelectElement;
    const r = await fetch('/api/v1/workouts', { credentials: 'include' });
    if (!r.ok) return;
    const body = (await r.json()) as { items: { id: string; name: string }[] };
    sel.innerHTML = '<option value="">— note only —</option>';
    for (const w of body.items) {
      const opt = document.createElement('option');
      opt.value = w.id;
      opt.textContent = w.name;
      sel.appendChild(opt);
    }
  }

  async function loadPlanned() {
    const list = document.getElementById('planned-list')!;
    const from = isoDaysAgo(28);
    const to = isoDaysAhead(56);
    const r = await fetch(`/api/v1/me/calendar?from=${from}&to=${to}`, { credentials: 'include' });
    if (!r.ok) return;
    const body = (await r.json()) as {
      items: {
        id: string;
        scheduledDate: string;
        notes: string | null;
        workoutName: string | null;
        sport: string | null;
        estimatedTss: number | null;
        completedActivityId: string | null;
        complianceScore: number | null;
      }[];
    };
    list.innerHTML = '';
    if (body.items.length === 0) {
      list.innerHTML = `<li class="caption">Nothing scheduled. Add a workout above to plan a session.</li>`;
      return;
    }
    for (const p of body.items) {
      const li = document.createElement('li');
      li.className = 'panel';
      const tag = p.completedActivityId
        ? `<span class="chip chip-success">done${p.complianceScore != null ? ` · ${Math.round(p.complianceScore * 100)}%` : ''}</span>`
        : `<span class="chip chip-muted">planned</span>`;
      const wname = p.workoutName ? escape(p.workoutName) : '<em>note</em>';
      li.innerHTML = `
        <div style="padding: 12px 16px; display: flex; align-items: center; gap: 12px;">
          <div style="flex: 1;">
            <div class="row" style="gap: 10px;">
              <strong style="font-family: var(--font-mono); font-size: 13px;">${p.scheduledDate}</strong>
              <span style="font-size: 14px;">${wname}</span>
              ${tag}
            </div>
            ${p.notes ? `<p class="caption" style="margin-top: 4px;">${escape(p.notes)}</p>` : ''}
          </div>
          <button data-del="${p.id}" type="button" class="btn btn-ghost btn-sm" style="color: var(--danger);">Remove</button>
        </div>
      `;
      list.appendChild(li);
    }
  }

  document.getElementById('schedule-form')!.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    const fd = new FormData(ev.target as HTMLFormElement);
    const payload = {
      scheduledDate: String(fd.get('scheduledDate') ?? ''),
      workoutId: String(fd.get('workoutId') ?? '') || null,
      notes: String(fd.get('notes') ?? '') || null,
    };
    const r = await fetch('/api/v1/me/calendar', {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (r.ok) {
      (ev.target as HTMLFormElement).reset();
      await loadPlanned();
    }
  });

  document.getElementById('planned-list')!.addEventListener('click', async (ev) => {
    const t = ev.target as HTMLElement;
    const id = t.dataset.del;
    if (!id) return;
    const r = await fetch(`/api/v1/me/calendar/${id}`, {
      method: 'DELETE',
      credentials: 'include',
    });
    if (r.ok) await loadPlanned();
  });

  function isoDaysAhead(n: number) {
    const d = new Date(Date.now() + n * 86_400_000);
    return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())}`;
  }

  function escape(s: string) {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function buildHeatmap(days: Day[]): SVGSVGElement {
    const cell = 13;
    const gap = 3;
    const totalDays = days.length;
    const cols = Math.ceil(totalDays / 7) + 1;
    const width = cols * (cell + gap) + 30;
    const height = 7 * (cell + gap) + 20;

    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('width', String(width));
    svg.setAttribute('height', String(height));
    svg.setAttribute('viewBox', `0 0 ${width} ${height}`);

    const max = Math.max(50, ...days.map((d) => d.tss));
    const firstDate = new Date(days[0]!.date + 'T00:00:00Z');
    const firstDow = firstDate.getUTCDay();

    for (let i = 0; i < days.length; i++) {
      const d = days[i]!;
      const offset = i + firstDow;
      const col = Math.floor(offset / 7);
      const row = offset % 7;
      const x = 30 + col * (cell + gap);
      const y = row * (cell + gap);

      const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
      rect.setAttribute('x', String(x));
      rect.setAttribute('y', String(y));
      rect.setAttribute('width', String(cell));
      rect.setAttribute('height', String(cell));
      rect.setAttribute('rx', '3');
      rect.setAttribute('fill', colorFor(d.tss, max));
      rect.addEventListener('mouseenter', () => {
        detail.textContent = `${d.date} · TSS ${d.tss.toFixed(0)}`;
      });
      svg.appendChild(rect);
    }

    ['Sun', '', 'Tue', '', 'Thu', '', 'Sat'].forEach((label, i) => {
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', '0');
      text.setAttribute('y', String(i * (cell + gap) + cell - 2));
      text.setAttribute('font-size', '10');
      text.setAttribute('font-family', 'var(--font-mono)');
      text.setAttribute('fill', 'var(--fg-muted)');
      text.textContent = label;
      svg.appendChild(text);
    });

    return svg;
  }

  function colorFor(tss: number, max: number): string {
    if (tss <= 0) return 'var(--zone-0)';
    const r = tss / max;
    if (r < 0.2) return 'var(--zone-1)';
    if (r < 0.4) return 'var(--zone-2)';
    if (r < 0.6) return 'var(--zone-3)';
    if (r < 0.85) return 'var(--zone-4)';
    return 'var(--zone-5)';
  }

  function isoToday() {
    const d = new Date();
    return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())}`;
  }
  function isoDaysAgo(n: number) {
    const d = new Date(Date.now() - n * 86_400_000);
    return `${d.getUTCFullYear()}-${pad(d.getUTCMonth() + 1)}-${pad(d.getUTCDate())}`;
  }
  function pad(n: number) {
    return String(n).padStart(2, '0');
  }
</script>
